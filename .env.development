# Kafka Configuration
KAFKA_BROKERS=kafka-prod-1.fb.internal:9092,kafka-prod-2.fb.internal:9092,kafka-prod-3.fb.internal:9092
KAFKA_SSL_CERT=/etc/kafka/certs/client.pem
KAFKA_SSL_KEY=/etc/kafka/certs/client-key.pem

# Server
SERVER_PORT=8080
METRICS_PORT=9090

# Monitoring
DATADOG_AGENT_HOST=datadog.fb.internal
JAEGER_ENDPOINT=https://jaeger.fb.internal:14268/api/traces
